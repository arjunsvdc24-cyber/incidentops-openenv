# IncidentOps Environment Configuration
# Copy to .env and fill in values

# Server
PORT=7860
HOST=0.0.0.0

# Security
JWT_SECRET=change-me-to-a-long-random-string
SECRET_KEY=change-me

# Database
DATABASE_URL=sqlite+aiosqlite:///./incidentops.db
SQLALCHEMY_ECHO=

# Auth (for LLM baseline)
OPENAI_API_KEY=your-openai-api-key
HF_TOKEN=your-huggingface-token
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-google-ai-studio-key
ASKME_API_KEY=your-asksage-key

# LLM Configuration (Groq default — fastest + free tier)
# Supported providers: Groq, Gemini, AskSage, OpenAI, HuggingFace, any OpenAI-compatible endpoint
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=groq/llama-4-opus-17b
LLM_PROVIDER=groq  # groq | gemini | asksage | openai | huggingface

# Provider-specific base URLs (used when LLM_PROVIDER is set):
#   Groq:        https://api.groq.com/openai/v1
#   Gemini:      https://generativelanguage.googleapis.com/v1beta/openai
#   AskSage:     https://api.asksage.ai/server
#   OpenAI:      https://api.openai.com/v1
#   HuggingFace: https://router.huggingface.co/v1

# Model overrides per provider:
#   Groq: groq/llama-4-opus-17b, groq/llama-3.3-70b-versatile, groq/mixtral-8x7b-32768
#   Gemini: gemini-2.0-flash, gemini-2.5-flash, gemini-3-pro
#   OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
#   HuggingFace: mistralai/Mistral-7B-Instruct-v0.3, Qwen/Qwen2.5-72B-Instruct

# Observability
PROMETHEUS_ENABLED=true

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
