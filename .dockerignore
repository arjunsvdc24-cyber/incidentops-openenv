# ─────────────────────────────────────────────────────────────
# IncidentOps .dockerignore
# Exclude everything not needed in production image
# ─────────────────────────────────────────────────────────────

# Git
.git
.gitignore

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg

# Testing
.pytest_cache
.coverage
cov_report.txt
htmlcov/
tests/
*.test.py

# Development & secrets
.env
.env.local
.env.*.local
.venv/
venv/
ENV/
.vscode/
.idea/
*.swp
*.swo

# Claude / agent context (NOT needed in image)
.claude-flow/
.claude/
RULES.txt
RULES/

# Node (already has node_modules but be thorough)
dashboard/node_modules

# Logs and outputs
logs/
output.log
*.log

# Docker
Dockerfile
docker-compose*.yml

# Documentation (not needed in image)
# EXCEPTION: CLAUDE.md is kept for project context at runtime
# *.md excluded below except CLAUDE.md is re-added at end

# CI/CD
.github/
.github/workflows/

# Database and caches
*.db
incidentops.db
*.sqlite

# Build artifacts (stale static assets tracked in git — use builder output instead)
app/static/

# Extra: keep CLAUDE.md for project-level context at runtime
CLAUDE.md